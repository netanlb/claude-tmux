{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "tmux set-option -w -t \"$TMUX_PANE\" @claude_status idle 2>/dev/null || true",
            "async": true
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "tmux set-option -w -t \"$TMUX_PANE\" -u @claude_status 2>/dev/null || true",
            "async": true
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "tmux set-option -w -t \"$TMUX_PANE\" @claude_status thinking 2>/dev/null || true",
            "async": true
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "tmux set-option -w -t \"$TMUX_PANE\" @claude_status thinking 2>/dev/null || true",
            "async": true
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "tmux set-option -w -t \"$TMUX_PANE\" @claude_status thinking 2>/dev/null || true",
            "async": true
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "tmux set-option -w -t \"$TMUX_PANE\" @claude_status waiting 2>/dev/null || true",
            "async": true
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "tmux set-option -w -t \"$TMUX_PANE\" @claude_status idle 2>/dev/null || true",
            "async": true
          }
        ]
      }
    ]
  }
}
